# ── Discord ────────────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Guild (server) ID for instant slash command sync during development.
# Remove or leave blank to sync globally (takes up to 1 hour to propagate).
DISCORD_GUILD_ID=

# Optional: restrict all bot commands to this channel ID.
# Leave blank to allow commands in any channel.
COMMAND_CHANNEL_ID=


# ── Agent VMs ──────────────────────────────────────────────────────────────────

# Comma-separated list of game VMs in the format  name:host:port
# The first entry is the default when no `vm` parameter is supplied.
#
# Examples:
#   Single VM:   AGENT_VMS=vm1:192.168.1.10:9000
#   Multiple:    AGENT_VMS=vm1:192.168.1.10:9000,vm2:192.168.1.11:9000
AGENT_VMS=vm1:127.0.0.1:9000

# Shared auth secret — must match GROMITBOT_AGENT_SECRET on every VM.
# Leave blank if auth is disabled on the agents.
AGENT_SECRET=
